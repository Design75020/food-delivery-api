# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT
JWT_SECRET="change_this_to_a_very_long_random_secret_at_least_64_chars"
JWT_EXPIRES_IN="7d"

# CORS (optional — leave empty to allow all origins)
CORS_ORIGIN=""
